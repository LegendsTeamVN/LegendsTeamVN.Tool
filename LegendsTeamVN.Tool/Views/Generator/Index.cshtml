@model IEnumerable<LegendsTeamVN.Tool.Models.TableInfo>

@{
    ViewData["Title"] = "Select Tables & Generate";
    var templates = ViewBag.Templates as List<string>;
    var connectionString = ViewBag.ConnectionString as string;
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold" style="color: var(--primary-color);">Generate CQRS MediatR Code</h2>
    
    <form asp-controller="Generator" asp-action="Generate" method="post">
        <input type="hidden" name="ConnectionString" value="@connectionString" />
        
        <div class="row mt-4">
            <div class="col-md-6 mb-4">
                <div class="card card-premium">
                    <div class="card-header card-header-gradient">
                        <h4 class="mb-0"><i class="bi bi-table"></i> 1. Select Tables</h4>
                    </div>
                    <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                        <ul class="list-group">
                            @foreach (var table in Model)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedTables" value="@table.Name" id="chk_@table.Name">
                                        <label class="form-check-label" for="chk_@table.Name">
                                            @table.Schema.@table.Name
                                        </label>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary btn-preview preview-btn" data-schema="@table.Schema" data-table="@table.Name">
                                        Preview Schema
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6 mb-4">
                <div class="card card-premium mb-4">
                    <div class="card-header card-header-gradient">
                        <h4 class="mb-0">2. Generate Code</h4>
                    </div>
                    <div class="card-body">
                        <div class="d-grid mt-2">
                            <button type="submit" class="btn btn-gradient btn-lg shadow-sm">Generate & Download Zip</button>
                        </div>
                    </div>
                </div>

                <div class="card card-premium">
                    <div class="card-header card-header-gradient">
                        <h4 class="mb-0">Table Schema Preview</h4>
                    </div>
                    <div class="card-body" id="preview-panel" style="max-height: 400px; overflow-y: auto;">
                        <p class="text-muted">Click "Preview Schema" on a table to view its properties and how they are mapped in the templates.</p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const previewBtns = document.querySelectorAll('.preview-btn');
            const previewPanel = document.getElementById('preview-panel');

            previewBtns.forEach(btn => {
                btn.addEventListener('click', async function (e) {
                    e.preventDefault();
                    const schema = this.getAttribute('data-schema');
                    const tableName = this.getAttribute('data-table');
                    
                    previewPanel.innerHTML = '<div class="text-center"><div class="spinner-border text-info" role="status"></div><p>Loading schema...</p></div>';

                    try {
                        const response = await fetch(`/Generator/TableDetails?schema=${schema}&tableName=${tableName}`);
                        if (!response.ok) throw new Error('Failed to load schema');
                        
                        const data = await response.json();
                        
                        let html = `<h5>${data.schema}.${data.name}</h5>`;
                        html += `<table class="table table-sm table-bordered mt-3">
                                    <thead>
                                        <tr>
                                            <th>Column Name</th>
                                            <th>C# Type</th>
                                            <th>Usage Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                        data.columns.forEach(col => {
                            let badge = '';
                            let usage = '';
                            
                            // Audit columns check
                            const auditCols = ['CreatedOnUtc', 'CreatedBy', 'ModifiedOnUtc', 'ModifiedBy', 'DeletedOnUtc', 'DeletedBy', 'IsDeleted'];
                            
                            if (col.isPrimaryKey || col.name === 'Id') {
                                badge = 'bg-primary';
                                usage = 'Read-Only (GetById, Update, Delete)';
                            } else if (auditCols.includes(col.name)) {
                                badge = 'bg-secondary';
                                usage = 'System/Audit (Excluded)';
                            } else {
                                badge = 'bg-success';
                                usage = 'Included (Create, Update, Get)';
                            }

                            html += `<tr>
                                        <td><strong>${col.name}</strong></td>
                                        <td><code>${col.systemType}</code></td>
                                        <td><span class="badge ${badge}">${usage}</span></td>
                                     </tr>`;
                        });
                        
                        html += `</tbody></table>`;
                        previewPanel.innerHTML = html;

                    } catch (error) {
                        previewPanel.innerHTML = `<div class="alert alert-danger">${error.message}</div>`;
                    }
                });
            });
        });
    </script>
}
