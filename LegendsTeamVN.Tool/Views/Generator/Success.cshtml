@model List<string>

@{
    ViewData["Title"] = "Generation Success";
}

<div class="container mt-5 text-center">
    <div class="alert alert-success shadow">
        <h2 class="alert-heading"><i class="bi bi-check-circle-fill"></i> Successfully Generated!</h2>
        <p>The following files were generated successfully at the target path:</p>
        <hr>
        <ul class="list-unstyled text-start d-inline-block">
            @foreach (var file in Model)
            {
                <li><i class="bi bi-file-earmark-code"></i> @file</li>
            }
        </ul>
        <div class="mt-4">
            <a asp-action="Index" class="btn btn-primary">Generate More</a>
        </div>
    </div>
</div>
